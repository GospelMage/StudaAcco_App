<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/receiptRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gs_surface"
    android:fillViewport="true"
    tools:context=".ReceiptActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/gs_screen_padding"
        android:paddingTop="@dimen/gs_space_section"
        android:paddingBottom="@dimen/gs_space_section">

        <TextView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/bg_status_available"
            android:gravity="center"
            android:text="✓"
            android:textColor="@color/gs_secondary"
            android:textSize="36sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/gs_space_large"
            android:text="@string/receipt_title"
            style="@style/TextAppearance.GabsStudentStay.ScreenTitle"
            android:textSize="26sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/gs_space_xlarge"
            app:cardBackgroundColor="@color/gs_surface_card"
            app:cardCornerRadius="@dimen/gs_card_radius"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/gs_card_padding">

                <TextView
                    android:id="@+id/tvReceiptReference"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/gs_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    tools:text="GST-1747674000000" />

                <TextView
                    android:id="@+id/tvReceiptRoom"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:textColor="@color/gs_text_primary"
                    android:textSize="16sp"
                    tools:text="Cozy Single Room near BAC" />

                <TextView
                    android:id="@+id/tvReceiptLocation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/gs_text_secondary"
                    android:textSize="14sp"
                    tools:text="Block 6" />

                <TextView
                    android:id="@+id/tvReceiptStudent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:textColor="@color/gs_text_primary"
                    android:textSize="15sp"
                    tools:text="Student User" />

                <TextView
                    android:id="@+id/tvReceiptAmount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:textColor="@color/gs_primary"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    tools:text="BWP 900 / month" />

                <TextView
                    android:id="@+id/tvReceiptDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:textColor="@color/gs_text_secondary"
                    android:textSize="14sp"
                    tools:text="2026-05-19 18:45" />

                <TextView
                    android:id="@+id/tvReceiptStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_status_available"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:text="@string/receipt_reserved_status"
                    android:textColor="@color/gs_secondary"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBackToHome"
            style="@style/Widget.GabsStudentStay.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="@string/receipt_back_home" />
    </LinearLayout>

</androidx.core.widget.NestedScrollView>

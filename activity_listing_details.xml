<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/detailsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gs_surface"
    tools:context=".ListingDetailsActivity">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="96dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/gs_hero_image_height">

                <ImageView
                    android:id="@+id/ivDetailImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    tools:src="@drawable/bg_listing_placeholder" />

                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="top|start"
                    android:layout_margin="@dimen/gs_space_large"
                    android:background="@color/white"
                    android:contentDescription="@string/details_title"
                    android:padding="8dp"
                    android:src="@android:drawable/ic_media_previous"
                    app:tint="@color/gs_primary" />

                <TextView
                    android:id="@+id/tvDetailStatusBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|end"
                    android:layout_margin="@dimen/gs_space_large"
                    android:background="@drawable/bg_status_available"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:text="@string/listing_status_available"
                    android:textColor="@color/gs_secondary"
                    android:textStyle="bold"
                    tools:text="@string/listing_status_reserved" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/gs_card_padding">

                <TextView
                    android:id="@+id/tvDetailTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/TextAppearance.GabsStudentStay.ScreenTitle"
                    tools:text="Cozy Single Room near BAC" />

                <TextView
                    android:id="@+id/tvDetailPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/gs_primary"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    tools:text="BWP 1,800 / month" />

                <TextView
                    android:id="@+id/tvDetailLocationType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/gs_space_medium"
                    android:textColor="@color/gs_text_secondary"
                    android:textSize="15sp"
                    tools:text="Block 6 • Single Room" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/gs_space_large"
                    android:orientation="horizontal">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="@color/gs_surface_card"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/details_availability"
                                android:textColor="@color/gs_text_secondary"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvDetailAvailability"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:textColor="@color/gs_text_primary"
                                android:textSize="15sp"
                                tools:text="2026-06-01" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="@color/gs_surface_card"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/details_deposit"
                                android:textColor="@color/gs_text_secondary"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvDetailDeposit"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:textColor="@color/gs_text_primary"
                                android:textSize="15sp"
                                tools:text="BWP 900" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/gs_space_large"
                    app:cardBackgroundColor="@color/gs_surface_card"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/details_amenities"
                            style="@style/TextAppearance.GabsStudentStay.SectionTitle" />

                        <TextView
                            android:id="@+id/tvDetailAmenities"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:textColor="@color/gs_text_secondary"
                            android:textSize="15sp"
                            tools:text="WiFi, Water Included, Security, Furnished" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/gs_space_large"
                    app:cardBackgroundColor="@color/gs_surface_card"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/details_provider"
                            style="@style/TextAppearance.GabsStudentStay.SectionTitle" />

                        <TextView
                            android:id="@+id/tvProviderName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:textColor="@color/gs_text_primary"
                            android:textSize="15sp"
                            tools:text="Tshepo Landlord" />

                        <TextView
                            android:id="@+id/tvProviderPhone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:textColor="@color/gs_text_secondary"
                            android:textSize="15sp"
                            tools:text="72 410 101" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/gs_space_large"
                    app:cardBackgroundColor="@color/gs_surface_card"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/details_campus"
                            style="@style/TextAppearance.GabsStudentStay.SectionTitle" />

                        <TextView
                            android:id="@+id/tvCampusName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:textColor="@color/gs_text_primary"
                            android:textSize="15sp"
                            tools:text="Botswana Accountancy College" />

                        <TextView
                            android:id="@+id/tvCampusDistance"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:textColor="@color/gs_text_secondary"
                            android:textSize="15sp"
                            tools:text="2.1 km from Botswana Accountancy College" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/gs_space_large"
                    app:cardBackgroundColor="@color/gs_surface_card"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/details_description"
                            style="@style/TextAppearance.GabsStudentStay.SectionTitle" />

                        <TextView
                            android:id="@+id/tvDescription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:textColor="@color/gs_text_secondary"
                            android:textSize="15sp"
                            tools:text="Comfortable single room close to campus with secure access and furnished study area." />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/gs_surface_card"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/gs_card_padding_compact"
        android:paddingTop="@dimen/gs_space_medium"
        android:paddingBottom="@dimen/gs_space_large">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnViewRoute"
            style="@style/Widget.GabsStudentStay.Button.Outlined"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:text="@string/details_view_route" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnReserveRoom"
            style="@style/Widget.GabsStudentStay.Button.Primary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/details_reserve_room" />
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>

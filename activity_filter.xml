<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/filterRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gs_surface"
    android:fillViewport="true"
    tools:context=".FilterActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/gs_screen_padding"
        android:paddingTop="@dimen/gs_screen_padding"
        android:paddingBottom="@dimen/gs_space_section">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFilterBack"
            style="@style/Widget.GabsStudentStay.Button.Text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/action_back"
            app:icon="@android:drawable/ic_media_previous"
            app:iconTint="@color/gs_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/gs_space_small"
            android:text="@string/filter_title"
            style="@style/TextAppearance.GabsStudentStay.ScreenTitle" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/gs_space_large"
            app:cardBackgroundColor="@color/gs_surface_card"
            app:cardCornerRadius="@dimen/gs_card_radius"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/gs_card_padding">

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.GabsStudentStay.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/filter_max_price">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etMaxPrice"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:minHeight="@dimen/gs_input_min_height"
                        android:textColor="@color/gs_text_primary"
                        tools:text="2500" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/gs_space_large"
                    android:text="@string/filter_location"
                    style="@style/TextAppearance.GabsStudentStay.SectionTitle" />

                <Spinner
                    android:id="@+id/spinnerLocation"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/gs_input_min_height"
                    android:layout_marginTop="@dimen/gs_space_small"
                    android:background="@drawable/bg_input_surface"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="14dp" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.GabsStudentStay.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/gs_space_large"
                    android:hint="@string/filter_availability_date">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etAvailabilityDate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="date"
                        android:minHeight="@dimen/gs_input_min_height"
                        android:textColor="@color/gs_text_primary"
                        tools:text="2026-06-15" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/gs_space_xlarge"
                    android:text="@string/filter_amenities"
                    style="@style/TextAppearance.GabsStudentStay.SectionTitle" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/gs_space_medium"
                    android:orientation="vertical">

                    <CheckBox
                        android:id="@+id/cbWifi"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/filter_wifi"
                        android:textColor="@color/gs_text_primary" />

                    <CheckBox
                        android:id="@+id/cbWaterIncluded"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/filter_water"
                        android:textColor="@color/gs_text_primary" />

                    <CheckBox
                        android:id="@+id/cbElectricityIncluded"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/filter_electricity"
                        android:textColor="@color/gs_text_primary" />

                    <CheckBox
                        android:id="@+id/cbSecurity"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/filter_security"
                        android:textColor="@color/gs_text_primary" />

                    <CheckBox
                        android:id="@+id/cbFurnished"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/filter_furnished"
                        android:textColor="@color/gs_text_primary" />

                    <CheckBox
                        android:id="@+id/cbParking"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/filter_parking"
                        android:textColor="@color/gs_text_primary" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnApplyFilters"
                    style="@style/Widget.GabsStudentStay.Button.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/gs_space_section"
                    android:text="@string/filter_apply" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSavePreferences"
                    style="@style/Widget.GabsStudentStay.Button.Outlined"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/gs_space_medium"
                    android:text="@string/filter_save_preferences" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnClearFilters"
                    style="@style/Widget.GabsStudentStay.Button.Text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="@dimen/gs_space_small"
                    android:text="@string/filter_clear" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

</androidx.core.widget.NestedScrollView>

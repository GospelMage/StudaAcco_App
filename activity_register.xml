<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/registerRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gs_surface"
    android:fillViewport="true"
    tools:context=".RegisterActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/gs_screen_padding"
        android:paddingTop="@dimen/gs_space_xlarge"
        android:paddingBottom="@dimen/gs_space_section">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/gs_space_small"
            app:cardBackgroundColor="@color/gs_surface_card"
            app:cardCornerRadius="@dimen/gs_card_radius_large"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/gs_screen_padding_large">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/register_title"
                    style="@style/TextAppearance.GabsStudentStay.ScreenTitle" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/gs_space_small"
                    android:text="@string/register_subtitle"
                    style="@style/TextAppearance.GabsStudentStay.ScreenSubtitle" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilRegisterFullName"
                    style="@style/Widget.GabsStudentStay.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/gs_space_section"
                    android:hint="@string/label_full_name">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etRegisterFullName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPersonName"
                        android:minHeight="@dimen/gs_input_min_height"
                        android:paddingTop="18dp"
                        android:paddingBottom="10dp"
                        android:textColor="@color/gs_text_primary" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilRegisterEmail"
                    style="@style/Widget.GabsStudentStay.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/gs_space_large"
                    android:hint="@string/label_email">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etRegisterEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textEmailAddress"
                        android:minHeight="@dimen/gs_input_min_height"
                        android:paddingTop="18dp"
                        android:paddingBottom="10dp"
                        android:textColor="@color/gs_text_primary" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilRegisterPhone"
                    style="@style/Widget.GabsStudentStay.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/gs_space_large"
                    android:hint="@string/label_phone">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etRegisterPhone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="phone"
                        android:minHeight="@dimen/gs_input_min_height"
                        android:paddingTop="18dp"
                        android:paddingBottom="10dp"
                        android:textColor="@color/gs_text_primary" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilRegisterPassword"
                    style="@style/Widget.GabsStudentStay.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/gs_space_large"
                    android:hint="@string/label_password"
                    app:endIconMode="password_toggle">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etRegisterPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:minHeight="@dimen/gs_input_min_height"
                        android:paddingTop="18dp"
                        android:paddingBottom="10dp"
                        android:textColor="@color/gs_text_primary" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilRegisterConfirmPassword"
                    style="@style/Widget.GabsStudentStay.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/gs_space_large"
                    android:hint="@string/label_confirm_password"
                    app:endIconMode="password_toggle">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etRegisterConfirmPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:minHeight="@dimen/gs_input_min_height"
                        android:paddingTop="18dp"
                        android:paddingBottom="10dp"
                        android:textColor="@color/gs_text_primary" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/gs_space_large"
                    android:text="@string/label_role"
                    style="@style/TextAppearance.GabsStudentStay.SectionTitle" />

                <Spinner
                    android:id="@+id/spinnerRole"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/gs_input_min_height"
                    android:layout_marginTop="@dimen/gs_space_small"
                    android:background="@drawable/bg_input_surface"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="14dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCreateAccount"
                    style="@style/Widget.GabsStudentStay.Button.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/gs_space_section"
                    android:text="@string/action_create_account"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGoToLogin"
                    style="@style/Widget.GabsStudentStay.Button.Text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="14dp"
                    android:text="@string/action_login" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

</androidx.core.widget.NestedScrollView>

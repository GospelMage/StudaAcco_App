<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardAlertMatch"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/gs_space_medium"
    app:cardBackgroundColor="@color/gs_surface_card"
    app:cardCornerRadius="@dimen/gs_card_radius"
    app:cardElevation="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/gs_card_padding_compact">

        <TextView
            android:id="@+id/tvMatchTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/gs_text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="Cozy Single Room near BAC" />

        <TextView
            android:id="@+id/tvMatchLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/gs_text_secondary"
            android:textSize="14sp"
            tools:text="Block 6" />

        <TextView
            android:id="@+id/tvMatchPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/gs_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            tools:text="BWP 1,800 / month" />

        <TextView
            android:id="@+id/tvMatchAvailability"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/gs_text_secondary"
            android:textSize="14sp"
            tools:text="Available: 2026-06-01" />
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>

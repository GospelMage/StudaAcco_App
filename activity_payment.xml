<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/paymentRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gs_surface"
    android:fillViewport="true"
    tools:context=".PaymentActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/gs_screen_padding"
        android:paddingTop="@dimen/gs_screen_padding"
        android:paddingBottom="@dimen/gs_space_section">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPaymentBack"
            style="@style/Widget.GabsStudentStay.Button.Text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/action_back"
            app:icon="@android:drawable/ic_media_previous"
            app:iconTint="@color/gs_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/gs_space_small"
            android:text="@string/payment_title"
            style="@style/TextAppearance.GabsStudentStay.ScreenTitle" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/gs_header_margin_small"
            android:text="@string/payment_subtitle"
            style="@style/TextAppearance.GabsStudentStay.ScreenSubtitle" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/gs_space_large"
            app:cardBackgroundColor="@color/gs_surface_card"
            app:cardCornerRadius="@dimen/gs_card_radius"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/gs_card_padding">

                <TextView
                    android:id="@+id/tvPaymentRoomTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/gs_text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    tools:text="Cozy Single Room near BAC" />

                <TextView
                    android:id="@+id/tvPaymentLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/gs_text_secondary"
                    android:textSize="14sp"
                    tools:text="Block 6" />

                <TextView
                    android:id="@+id/tvPaymentDeposit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textColor="@color/gs_primary"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    tools:text="BWP 900 / month" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/gs_space_large"
            app:cardBackgroundColor="@color/gs_surface_card"
            app:cardCornerRadius="@dimen/gs_card_radius"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/gs_card_padding">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/payment_method"
                    style="@style/TextAppearance.GabsStudentStay.SectionTitle" />

                <RadioGroup
                    android:id="@+id/rgPaymentMethod"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/gs_space_medium">

                    <RadioButton
                        android:id="@+id/rbCardPayment"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="8dp"
                        android:text="@string/payment_card"
                        android:textColor="@color/gs_text_primary" />

                    <RadioButton
                        android:id="@+id/rbMobileMoney"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="8dp"
                        android:text="@string/payment_mobile_money"
                        android:textColor="@color/gs_text_primary" />

                    <RadioButton
                        android:id="@+id/rbBankTransfer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="8dp"
                        android:text="@string/payment_bank_transfer"
                        android:textColor="@color/gs_text_primary" />
                </RadioGroup>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.GabsStudentStay.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:hint="@string/payment_name_on_payment">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etNameOnPayment"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="@dimen/gs_input_min_height"
                        android:textColor="@color/gs_text_primary"
                        tools:text="Tebogo Mothibi" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.GabsStudentStay.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:hint="@string/payment_phone_number">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPhoneNumber"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="phone"
                        android:minHeight="@dimen/gs_input_min_height"
                        android:textColor="@color/gs_text_primary"
                        tools:text="71 000 001" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.GabsStudentStay.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:hint="@string/payment_reference_note">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etReferenceNote"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="@dimen/gs_input_min_height"
                        android:textColor="@color/gs_text_primary" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:id="@+id/tvPaymentSandboxNote"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/gs_space_large"
                    android:background="@drawable/bg_chip_soft"
                    android:padding="12dp"
                    android:text="@string/payment_sandbox_note"
                    android:textColor="@color/gs_text_secondary"
                    android:textSize="13sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnConfirmPayment"
                    style="@style/Widget.GabsStudentStay.Button.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/gs_space_xlarge"
                    android:text="@string/payment_confirm" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

</androidx.core.widget.NestedScrollView>
